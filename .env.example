APP_NAME=Crab Farm Backend
APP_ENV=local
DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
SIMULATION_MODE=true

DATABASE_URL=postgresql+asyncpg://crab:crab@postgres:5432/crab_farm

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=crab-farm-backend
MQTT_KEEPALIVE=60
MQTT_SIMULATE_PUBLISH=false

CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
STORAGE_DIR=storage
PUBLIC_STORAGE_URL=/storage

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

MOLTING_RECHECK_MINUTES=10
UNCERTAIN_RECHECK_MINUTES=3
SOFT_SHELL_VERIFY_SECONDS=60
SOFT_SHELL_CONFIDENCE_THRESHOLD=0.85
MOTION_TIMEOUT_SECONDS=60
CAMERA_TIMEOUT_SECONDS=30
AI_TIMEOUT_SECONDS=30
MOTION_SETTLE_MS=800

AI_ENABLED=true
AI_MOCK_MODE=false
AI_MODEL_PATH=storage/models/crab_yolov8_v1.pt
AI_MODEL_VERSION=crab_yolov8_v1
AI_CONFIDENCE_THRESHOLD=0.5
AI_IMAGE_SIZE=640
